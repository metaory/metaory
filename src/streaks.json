[
  [
    "div",
    { "align": "center", "valign": "center" },
    ["br"],
    [
      "img",
      {
        "valign": "center",
        "height": "$SH",
        "width": "30%",
        "src": [
          "https://github-readme-stats.vercel.app/api?",
          {
            "bg_color": "$BG",
            "border_radius": "$RD",
            "count_private": true,
            "disable_animations": false,
            "hide_border": true,
            "hide_rank": false,
            "hide_title": true,
            "include_all_commits": true,
            "locale": "en",
            "ring_color": "$XG",
            "show": "$SSHOW",
            "show_icons": true,
            "text_color": "$FG",
            "username": "$USR"
          }
        ]
      }
    ],
    [
      "img",
      {
        "height": "$CH",
        "valign": "center",
        "src": [
          "https://streak-stats.demolab.com?",
          {
            "background": "$GR",
            "border_radius": "$RD",
            "card_width": "$CW",
            "currStreakLabel": "$C4",
            "currStreakNum": "$C1",
            "dates": "$C5",
            "excludeDaysLabel": "$C3",
            "fire": "$C4",
            "hide_border": true,
            "hide_current_streak": false,
            "hide_longest_streak": true,
            "hide_total_contributions": true,
            "mode": "weekly",
            "ring": "$C5",
            "sideLabels": "$C4",
            "sideNums": "$C5",
            "stroke": "$C6",
            "theme": "$STREAK_THEME",
            "user": "$USR"
          }
        ]
      }
    ],
    [
      "img",
      {
        "height": "$CH",
        "valign": "center",
        "src": [
          "https://streak-stats.demolab.com?",
          {
            "background": "$GR",
            "border_radius": "$RD",
            "card_width": "$CW",
            "currStreakLabel": "$C4",
            "currStreakNum": "$C1",
            "dates": "$C5",
            "excludeDaysLabel": "$C3",
            "fire": "$C4",
            "hide_border": true,
            "hide_current_streak": true,
            "hide_longest_streak": false,
            "hide_total_contributions": true,
            "mode": "weekly",
            "ring": "$C5",
            "sideLabels": "$C4",
            "sideNums": "$C5",
            "stroke": "$C6",
            "theme": "$STREAK_THEME",
            "user": "$USR"
          }
        ]
      }
    ],
    [
      "img",
      {
        "height": "$CH",
        "valign": "center",
        "src": [
          "https://streak-stats.demolab.com?",
          {
            "background": "$GR",
            "border_radius": "$RD",
            "card_width": "$CW",
            "currStreakLabel": "$C4",
            "currStreakNum": "$C1",
            "dates": "$C5",
            "excludeDaysLabel": "$C3",
            "fire": "$C4",
            "hide_border": true,
            "hide_current_streak": true,
            "hide_longest_streak": true,
            "hide_total_contributions": false,
            "mode": "weekly",
            "ring": "$C5",
            "sideLabels": "$C4",
            "sideNums": "$C5",
            "stroke": "$C6",
            "theme": "$STREAK_THEME",
            "user": "$USR"
          }
        ]
      }
    ]
  ]
]
